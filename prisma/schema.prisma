generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model User {
  id                  String     @id @default(cuid())
  email               String     @unique
  passwordHash        String     @map("password_hash")
  role                UserRole   @default(USER)
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?  @map("locked_until")
  lastFailedLoginAt   DateTime?  @map("last_failed_login_at")
  status              UserStatus @default(ACTIVE)
  emailVerifiedAt     DateTime?  @map("email_verified_at")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  sessions            Session[]
  authCodes           AuthCode[]
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]
  createdInviteCodes  InviteCode[]         @relation("CreatedInvites")
  inviteCodeUsages    InviteCodeUsage[]

  @@map("users")
}

model InviteCode {
  id              String    @id @default(cuid())
  code            String    @unique
  createdByUserId String?   @map("created_by_user_id")
  assignedEmail   String?   @map("assigned_email")
  maxUses         Int       @default(1) @map("max_uses")
  usedCount       Int       @default(0) @map("used_count")
  expiresAt       DateTime? @map("expires_at")
  revokedAt       DateTime? @map("revoked_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  createdBy User?             @relation("CreatedInvites", fields: [createdByUserId], references: [id], onDelete: SetNull)
  usages    InviteCodeUsage[]

  @@index([createdByUserId])
  @@map("invite_codes")
}

model InviteCodeUsage {
  id           String   @id @default(cuid())
  inviteCodeId String   @map("invite_code_id")
  usedByUserId String   @map("used_by_user_id")
  usedEmail    String   @map("used_email")
  createdAt    DateTime @default(now()) @map("created_at")

  inviteCode InviteCode @relation(fields: [inviteCodeId], references: [id], onDelete: Cascade)
  usedBy     User       @relation(fields: [usedByUserId], references: [id], onDelete: Cascade)

  @@index([inviteCodeId])
  @@index([usedByUserId])
  @@map("invite_code_usages")
}

enum ClientType {
  PUBLIC
  CONFIDENTIAL
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

model Client {
  id                     String       @id @default(cuid())
  name                   String
  slug                   String       @unique
  clientId               String       @unique @map("client_id")
  clientSecretHash       String?      @map("client_secret_hash")
  type                   ClientType   @default(PUBLIC)
  redirectUris           String[]     @map("redirect_uris")
  postLogoutRedirectUris String[]     @map("post_logout_redirect_uris")
  scopes                 String[]     @default(["openid", "profile", "email"])
  status                 ClientStatus @default(ACTIVE)
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedAt              DateTime     @updatedAt @map("updated_at")

  authCodes AuthCode[]
  sessions  Session[]
  auditLogs AuditLog[]

  @@map("clients")
}

model AuthCode {
  id                  String    @id @default(cuid())
  codeHash            String    @unique @map("code_hash")
  userId              String    @map("user_id")
  clientId            String    @map("client_id")
  redirectUri         String    @map("redirect_uri")
  scope               String    @default("openid email")
  codeChallenge       String    @map("code_challenge")
  codeChallengeMethod String    @default("S256") @map("code_challenge_method")
  expiresAt           DateTime  @map("expires_at")
  consumedAt          DateTime? @map("consumed_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
  @@map("auth_codes")
}

model Session {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  clientId         String?   @map("client_id")
  sessionTokenHash String    @unique @map("session_token_hash")
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  lastSeenAt       DateTime  @default(now()) @map("last_seen_at")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([clientId])
  @@map("sessions")
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  clientId  String?  @map("client_id")
  eventType String   @map("event_type")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("audit_logs")
}
